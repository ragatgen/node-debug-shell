#!/usr/bin/env python3

import shutil
import subprocess
import sys


PLUGIN_COMMAND = "kubectl aks-node-debug"
DEBUG_IMAGE = "mcr.microsoft.com/cbl-mariner/busybox:2.0"


def run_command(command, capture=True, check=False):
    try:
        return subprocess.run(
            command,
            text=True,
            capture_output=capture,
            check=check,
        )
    except FileNotFoundError:
        return None


def show_help():
    print(f"""Usage: {PLUGIN_COMMAND}

Starts an interactive node-level debug session in an Azure Kubernetes Service (AKS) cluster.

Prerequisites:
  - kubectl must be installed and configured.
  - Azure CLI must be installed and authenticated.
  - You must be connected to an AKS cluster.
  - The cluster must support 'kubectl debug'.
  - Your user must have permissions to list nodes and create debug pods.

Example:
  {PLUGIN_COMMAND}
""")
    sys.exit(0)


def fail(message):
    print(f"Error: {message}", file=sys.stderr)
    sys.exit(1)


def main():
    if len(sys.argv) > 1 and sys.argv[1] in ("--help", "-h"):
        show_help()

    if not shutil.which("kubectl"):
        fail("kubectl is not installed or not available in PATH.")

    if not shutil.which("az"):
        fail("Azure CLI is not installed or not available in PATH.")

    az_login = run_command(["az", "account", "show"])
    if az_login is None or az_login.returncode != 0:
        fail("You are not logged into Azure. Run 'az login' first.")

    context = run_command(["kubectl", "config", "current-context"])
    if context is None or context.returncode != 0 or not context.stdout.strip():
        fail("No Kubernetes context is currently selected. Run: az aks get-credentials --resource-group <resource-group> --name <cluster-name>")

    current_context = context.stdout.strip()

    if "aks" not in current_context.lower():
        fail(
            f"Current context '{current_context}' does not appear to be an AKS context. "
            "Run: az aks get-credentials --resource-group <resource-group> --name <cluster-name>"
        )

    can_get_nodes = run_command(["kubectl", "auth", "can-i", "get", "nodes"])
    if can_get_nodes is None or can_get_nodes.returncode != 0 or can_get_nodes.stdout.strip().lower() != "yes":
        fail("Your Kubernetes identity cannot list nodes.")

    can_create_pods = run_command(["kubectl", "auth", "can-i", "create", "pods"])
    if can_create_pods is None or can_create_pods.returncode != 0 or can_create_pods.stdout.strip().lower() != "yes":
        fail("Your Kubernetes identity cannot create debug pods.")

    debug_help = run_command(["kubectl", "debug", "--help"])
    if debug_help is None or debug_help.returncode != 0:
        fail("'kubectl debug' is not available in your kubectl client.")

    node_result = run_command(["kubectl", "get", "nodes", "-o", "name"])
    if node_result is None or node_result.returncode != 0:
        fail("Unable to retrieve nodes from the current cluster.")

    nodes = [
        line.replace("node/", "").strip()
        for line in node_result.stdout.splitlines()
        if line.strip().startswith("node/")
    ]

    if not nodes:
        fail("No nodes found in the current cluster.")

    print("Available nodes in your AKS cluster:\n")

    for index, node in enumerate(nodes, start=1):
        print(f"{index}) {node}")

    print()

    try:
        choice = input("Choose one node by number: ").strip()
    except KeyboardInterrupt:
        print("\nOperation cancelled.")
        sys.exit(1)

    if not choice.isdigit():
        fail("Invalid choice. Please enter a number.")

    selected_index = int(choice)

    if selected_index < 1 or selected_index > len(nodes):
        fail(f"Invalid choice. Please select a number between 1 and {len(nodes)}.")

    node_name = nodes[selected_index - 1]

    print(f"\nYou selected: {node_name}")
    print(f"Starting debug session on node: {node_name}\n")

    debug_command = [
        "kubectl",
        "debug",
        f"node/{node_name}",
        "-it",
        f"--image={DEBUG_IMAGE}",
        "--",
        "chroot",
        "/host",
    ]

    subprocess.run(debug_command)

    print(f"\nExited debug session for node: {node_name}")


if __name__ == "__main__":
    main()
